# .env.local — Copy this file and fill in your Firebase credentials.
# NEVER commit .env.local to version control.

# ── Firebase ──────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# ── App Config ────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Companio

# ── Admin ─────────────────────────────────────────────
# Set these UIDs as admin in Firestore manually:
# db.collection('users').doc(ADMIN_UID).update({ role: 'admin' })
ADMIN_EMAIL=admin@companio.in
